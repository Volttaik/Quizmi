{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/chat/[sessionId]",
      "regex": "^/api/chat/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPsessionId": "nxtPsessionId"
      },
      "namedRegex": "^/api/chat/(?<nxtPsessionId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/flashcard-sets/[id]",
      "regex": "^/api/flashcard\\-sets/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/flashcard\\-sets/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/quizzes/slug/[slug]",
      "regex": "^/api/quizzes/slug/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/api/quizzes/slug/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/quizzes/[id]",
      "regex": "^/api/quizzes/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/quizzes/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/q/[slug]",
